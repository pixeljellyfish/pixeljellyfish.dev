---
import { Icon } from 'astro-icon';

interface Props {
    repo: string;
    id: string;
    bgColor?: string;
}

const { repo, id, bgColor = "bg-gray-500" } = Astro.props;

let name = 'Loading';
let description = 'Loading';
let starDisplay = 'Loading';

try {
    const res = await fetch(`https://api.github.com/repos/pixeljellyfish/${repo}`, {
        headers: {
            Authorization: `token ${import.meta.env.GH_TOKEN || 'default-token'}`
        }
    });
    if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
    const data = await res.json();
    name = data.name || 'Unnamed Repo';
    description = data.description || 'No description available';
    starDisplay = data.stargazers_count === 0 ? 'No stars yet' : data.stargazers_count;
} catch (error) {
    console.error(`Failed to fetch repo ${repo} at build time:`, error);
    name = 'Error';
    description = 'Could not load repository data';
    starDisplay = 'N/A';
}
---

<a
    href={`https://github.com/pixeljellyfish/${repo}`}
    rel="noopener noreferrer"
    target="_blank"
    class={`flex-grow h-24 sm:h-28 focus:outline-none transition duration-300 ease-in-out transform hover:scale-105 p-3 rounded-md border border-gray-800 shadow flex items-center justify-between ${bgColor}`}
>
    <div class="my-auto">
        <div class="font-semibold text-base sm:text-lg">
            {name}
        </div>
        <p class="text-xs sm:text-sm">
            {description}
        </p>
    </div>
    <div class="font-semibold text-sm sm:text-base">
        <Icon name="mdi:star" className="fill-white h-[1em] inline" />
        <span>{starDisplay}</span>
    </div>
</a>