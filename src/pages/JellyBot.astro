---
import jellybot from '../data/JellyBot.json';

const categories = ['all', ...new Set(jellybot.map(jellybot => jellybot.category))];
---

<style>
  .row { @apply mx-[-16px] p-2; }
  .column { @apply float-left w-1/4 hidden p-2; }
  .content { @apply bg-white p-2 border border-gray-300; }
  .show { @apply block; }
  .btn { @apply border-none px-4 py-2 bg-gray-500 cursor-pointer; }
  .btn:hover { @apply bg-blue-600; }
  .btn.active { @apply bg-blue-600 text-white; }
  @media (max-width: 900px) { .column { @apply w-1/2; } }
  @media (max-width: 600px) { .column { @apply w-full; } }
</style>

<div id="myBtnContainer">
  {categories.map(category => (
    <button class="btn" onclick="filterSelection('{category}')">{category}</button>
  ))}
</div>

<div class="row">
  {jellybot.map(jellybot => (
    <div class="column {project.category}">
      <div class="content">
        <h3>{jellybot.title}</h3>
        <p>{jellybot.description}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .row { margin: 8px -16px; }
  .row, .row > .column { padding: 8px; }
  .column { float: left; width: 25%; display: none; }
  .content { background-color: white; padding: 10px; border: 1px solid gray; }
  .show { display: block; }
  .btn { border: none; padding: 8px 14px; background-color: gray; cursor: pointer; }
  .btn:hover { background-color: #007EE5; }
  .btn.active { background-color: #007EE5; color: white; }
  @media screen and (max-width: 900px) { .column { width: 50%; } }
  @media screen and (max-width: 600px) { .column { width: 100%; } }
</style>

<script>
  filterSelection("all");
  function filterSelection(c: string) {
    let x = document.getElementsByClassName("column");
    if (c === "all") c = "";
    for (let i = 0; i < x.length; i++) {
      x[i].classList.remove("show");
      if (x[i].className.indexOf(c) > -1) x[i].classList.add("show");
    }
  }

  let btnContainer = document.getElementById("myBtnContainer");
  if (btnContainer) {
    let btns = btnContainer.getElementsByClassName("btn");
    for (let i = 0; i < btns.length; i++) {
      btns[i].addEventListener("click", function (this: HTMLButtonElement) {
        let current = document.getElementsByClassName("active");
        if (current.length > 0) current[0].className = current[0].className.replace(" active", "");
        this.className += " active";
      });
    }
  }
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    import('..//scripts/jellyfish.js').then(({ initJellyfishAnimation }) => {
      const cleanup = initJellyfishAnimation();
      window.addEventListener('beforeunload', cleanup);
    }).catch(err => console.error('Failed to load jellyfish.js:', err));
  });
</script>