---
import Layout from '@layouts/Default.astro';
import MusicCard from '@components/MusicCard';
import Time from '@components/Time';
import DiscordStatus from '@components/DiscordStatus';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCard from '@components/SkillCard.astro';
import SocialIcon from '@components/SocialIcon.astro';
import { Icon } from 'astro-icon';

// Fetch weather data during build time
const res = await fetch(`https://api.openweathermap.org/data/2.5/weather?q=gracemere&units=metric&appid=858d5bda17434ce3864d63491b44deb4&lang=en`); // Replace with your own API key
const data = await res.json(); // Parse JSON
const temp_c = data.main.temp; // Celsius
const temp_f = temp_c * 9 / 5 + 32; // Convert to Fahrenheit manually
---

<Layout>
    <h1 class="mb-1 text-white interactive">
      <span class="bg-gradient-to-r from-blue-600 to-[#ff6c7b] animate-[gradient_3s_ease-in-out_infinite] clip">I'm Pixeljellyfish, a developer from Brisbane Australia.</span>
    </h1>
    <h2 class="font-normal mb-2 text-sky-300 interactive">
      <span id="weather" class="font-medium text-sky-300" data-celsius={Math.round(temp_c)} data-fahrenheit={Math.round(temp_f)}>{Math.round(temp_c)}°C</span> in Brisbane Australia
    </h2>
    <h3 class="font-normal mb-4 text-amber-300 interactive">
      <Icon name="mdi:clock" class="fill-amber-500 h-5 inline" /> <Time client:only="react" />
    </h3>
    <p class="mb-4 text-white interactive">
      I'm a <span class="text-green-600">developer</span> who loves to create and contribute to <span class="text-purple-600">open-source</span> projects. I'm currently working on a few <span class="text-blue-600">projects</span>, and I'm always looking for new opportunities to learn and grow.
    </p>
    <div class="grid grid-flow-col w-48 mt-3 text-lg mb-5 interactive">
      <SocialIcon name="Twitter" href="https://twitter.com/pixeljellyfish" icon="twitter" />
      <SocialIcon name="codedex" href="https://www.codedex.io/@Pixeljellyfish" icon="codedex" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 interactive">
      <MusicCard client:only="react"/>
      <DiscordStatus client:only="react"/>
    </div>

    <!-- Projects -->
    <h3 class="font-medium mt-12">Projects</h3>
    <p class="mb-4">These are projects that I have either created or contributed to. I only feature my favorite projects here.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <ProjectCard repo="c0mebackf0lders" id="4ZHCtv" />
        <ProjectCard repo="pixeljellyfish.dev" id="xGHSiy" />
        <ProjectCard repo="repo" id="eZ2hS8" />
        <ProjectCard repo="OS-Stuff" id="y5Bs8x" />
    </div>

    <h2 class="font-medium mt-12 text-white interactive">Skills</h2>
    <p class="mb-4 text-white interactive">
      These are some of the <span class="text-cyan-600">skills</span> I use to <span class="text-pink-600">create</span> my <span class="text-lime-600">projects</span>.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mt-4 text-white interactive">
      <SkillCard name="VS Code" icon="vscode-icons:file-type-vscode2" website="https://code.visualstudio.com" bgColor="bg-blue-700" />
      <SkillCard name="Figma" icon="logos:figma" website="https://www.figma.com" bgColor="bg-purple-600" />
      <SkillCard name="Javascript" icon="logos:javascript" website="https://developer.mozilla.org/en-US/docs/Web/JavaScript" bgColor="bg-yellow-500" />
      <SkillCard name="Typescript" icon="logos:typescript-icon" website="https://www.typescriptlang.org" bgColor="bg-blue-600" />
      <SkillCard name="Python" icon="logos:python" website="https://www.python.org" bgColor="bg-blue-800" />
      <SkillCard name="Swift" icon="logos:swift" website="https://www.swift.org" bgColor="bg-orange-600" />
      <SkillCard name="HTML" icon="logos:html-5" website="https://developer.mozilla.org/en-US/docs/Web/HTML" bgColor="bg-orange-500" />
      <SkillCard name="Tailwind" icon="logos:tailwindcss-icon" website="https://tailwindcss.com" bgColor="bg-teal-500" />
      <SkillCard name="c++" icon="logos:c-plusplus" website="https://isocpp.org" bgColor="bg-blue-900" />
      <SkillCard name="React" icon="logos:react" website="https://reactjs.org" bgColor="bg-cyan-500" />
      <SkillCard name="Bash" icon="logos:bash-icon" website="https://www.gnu.org/software/bash/" bgColor="bg-green-700" />
      <SkillCard name="Astro" icon="vscode-icons:file-type-astro" website="https://astro.build" bgColor="bg-gradient-to-r from-purple-700 to-orange-600" />
    </div>
    <br />
    <br />
    <footer class=" cstm-footer mb-5 flex flex-row items-center interactive px-4">
      <div class="flex space-x-4 sm:space-x-7">
        <p class="text-sm text-indigo-400 hover:scale-105 hover:brightness-125 transition-all duration-300 cstm-margin-right">
          © 2023 Pixeljellyfish. All rights reserved
        </p>
        <p class="text-sm text-emerald-400 hover:scale-105 hover:brightness-125 transition-all duration-300">
          Made with <a href="https://astro.build" class="text-[#FF5D01] hover:underline">Astro</a> and <a href="https://tailwindcss.com" class="text-[#38BDF8] hover:underline">Tailwind CSS</a>
        </p>
        <div class="flex-1 flex justify-center">
          <p class="text-sm text-lime-400 hover:scale-105 hover:brightness-125 transition-all duration-300 ml-20">
            Designed with <span class="text-purple-600 text-lg animate-[bounce_1s_ease-in-out_infinite] inline-block">❤️</span> and <span class="text-red-600">jellyfish magic</span>
          </p>
        </div>
      <div class="flex space-x-4 sm:space-x-7">
        <p class="text-sm text-rose-400 hover:scale-105 hover:brightness-125 transition-all duration-300 cstm-margin">
          Powered by <a href="https://vercel.com" class="text-black dark:text-white hover:underline">Vercel</a>
        </p>
        <p class="text-sm text-violet-400 hover:scale-105 hover:brightness-125 transition-all duration-300 cstm-margin-left">
          Hosted on <a href="https://github.com" class="text-[#24292E] dark:text-gray-300 hover:underline">GitHub</a>
        </p>
      </div>
    </footer>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    import('..//scripts/jellyfish.js').then(({ initJellyfishAnimation }) => {
      const cleanup = initJellyfishAnimation();
      window.addEventListener('beforeunload', cleanup);
    }).catch(err => console.error('Failed to load jellyfish.js:', err));
  });
</script>

<script defer>
  const weatherSpan = document.getElementById('weather');
  if (weatherSpan) {
    const celsius = parseInt(weatherSpan.dataset.celsius, 10);
    const fahrenheit = parseInt(weatherSpan.dataset.fahrenheit, 10);

    weatherSpan.addEventListener('mouseenter', () => {
      weatherSpan.textContent = `${fahrenheit}°F`;
    });
    weatherSpan.addEventListener('mouseleave', () => {
      weatherSpan.textContent = `${celsius}°C`;
    });
  } else {
    console.error('weather.js: Could not find weather span');
  }
</script>
