---
import Layout from '@layouts/Default.astro';
import MusicCard from '@components/MusicCard';
import Time from '@components/Time';
import DiscordStatus from '@components/DiscordStatus';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCard from '@components/SkillCard.astro';
import SocialIcon from '@components/SocialIcon.astro';
import { Icon } from 'astro-icon';


// Fetch weather data during build time
const res = await fetch(`https://api.openweathermap.org/data/2.5/weather?q=gracemere&units=metric&appid=854b0fbcd9fb2e7ab21c0afee1efde32&lang=en`);
const data = await res.json();
const temp_c = data.main.temp;
const temp_f = temp_c * 9 / 5 + 32;
---

<Layout>
    <!-- Inline critical CSS (generate separately using a tool like Critical) -->
    <style>
      /* Placeholder for inlined critical CSS */
      /* Example: h1 { font-size: 2.5rem; margin-bottom: 0.25rem; } */
    </style>
    <!-- Defer non-critical CSS -->
    <link rel="stylesheet" href="/_astro/index.Bpl_MU_A.css" media="print" onload="this.media='all'">

    <!-- Hero -->
    <h1 class="mb-1">
      I'm <span class="bg-gradient-to-r from-blue-600 to-[#ff6c7b] dark:from-blue-300 dark:to-[#ffacb4] animate-[gradient_3s_ease-in-out_infinite] clip">Pixeljellyfish</span>,
      a developer from Brisbane Australia.
    </h1>
    <h2 class="font-normal mb-2">
      <span id="weather" class="font-medium">{Math.round(temp_c)}°C</span> in Brisbane Australia
    </h2>
    <h3 class="font-normal mb-4">
      <Icon name="mdi:clock" class="fill-neutral-900 dark:fill-white h-5 inline" /> <Time client:only="react" />
    </h3>
    <p class="mb-4 text-gray-600 dark:text-gray-400">
      I'm a <span class="text-green-600 dark:text-green-400">developer</span> who loves to create and contribute to <span class="text-purple-600 dark:text-purple-400">open-source</span> projects. I'm currently working on a few <span class="text-blue-600 dark:text-blue-400">projects</span>, and I'm always looking for new opportunities to learn and grow.
    </p>
    <div class="grid grid-flow-col w-48 mt-3 text-lg mb-5">
      <SocialIcon name="Twitter" href="https://twitter.com/pixeljellyfish" icon="twitter" />
      <SocialIcon name="codedex" href="https://www.codedex.io/@Pixeljellyfish" icon="codedex" />
      <SocialIcon name="Discord" href="https://discord.gg/d7n9hZzMXn" icon="discord" />
      <SocialIcon name="Email" href="mailto:me@devpixel12@gmail.com" icon="gmail" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <MusicCard client:only="react"/>
      <DiscordStatus client:only="react"/>
    </div>

    <!-- Projects -->
    <h2 class="font-medium mt-12">Projects</h2>
    <p class="mb-4 text-gray-600 dark:text-gray-400">
      These are <span class="text-orange-600 dark:text-orange-400">projects</span> that I have either <span class="text-red-600 dark:text-red-400">created</span> or contributed to. I only feature my <span class="text-yellow-600 dark:text-yellow-400">favorite</span> projects here.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" style="min-height: 216px;">
      <ProjectCard repo="c0mebackf0lders" id="4ZHCtv" />
      <ProjectCard repo="pixeljellyfish.dev" id="xGHSiy" />
      <ProjectCard repo="repo" id="eZ2hS8" />
      <ProjectCard repo="OS-Stuff" id="y5Bs8x" />
    </div>

    <!-- Skills -->
    <h2 class="font-medium mt-12">Skills</h2>
    <p class="mb-4 text-gray-600 dark:text-gray-400">
      These are some of the <span class="text-cyan-600 dark:text-cyan-400">skills</span> I use to <span class="text-pink-600 dark:text-pink-400">create</span> my <span class="text-lime-600 dark:text-lime-400">projects</span>.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mt-4">
      <SkillCard name="VS Code" icon="vscode-icons:file-type-vscode2" website="https://code.visualstudio.com" />
      <SkillCard name="Figma" icon="logos:figma" website="https://www.figma.com" />
      <SkillCard name="Javascript" icon="logos:javascript" website="https://developer.mozilla.org/en-US/docs/Web/JavaScript" />
      <SkillCard name="Typescript" icon="logos:typescript-icon" website="https://www.typescriptlang.org" />
      <SkillCard name="Python" icon="logos:python" website="https://www.python.org" />
      <SkillCard name="Swift" icon="logos:swift" website="https://www.swift.org" />
      <SkillCard name="HTML" icon="logos:html-5" website="https://developer.mozilla.org/en-US/docs/Web/HTML" />
      <SkillCard name="Tailwind" icon="logos:tailwindcss-icon" website="https://tailwindcss.com" />
      <SkillCard name="c++" icon="logos:c-plusplus" website="https://isocpp.org" />
      <SkillCard name="React" icon="logos:react" website="https://reactjs.org" />
      <SkillCard name="Bash" icon="logos:bash-icon" website="https://www.gnu.org/software/bash/" />
      <SkillCard name="Astro" icon="vscode-icons:file-type-astro" website="https://astro.build" />
    </div>
</Layout>

<script>
  // Client-side script for weather hover effect
  const weatherElement = document.getElementById('weather');
  const tempC = Number.parseFloat(weatherElement?.textContent) || 0;
  const tempF = Math.round(tempC * 9 / 5 + 32);

  if (weatherElement) {
    weatherElement.addEventListener('mouseover', () => {
      weatherElement.innerHTML = `${tempF}°F`;
    });
    weatherElement.addEventListener('mouseout', () => {
      weatherElement.innerHTML = `${Math.round(tempC)}°C`;
    });
  }
</script>