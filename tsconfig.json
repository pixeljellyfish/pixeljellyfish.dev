{
  "compilerOptions": {
    "lib": ["es2016", "dom"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@styles/*": ["src/styles/*"],
      "@utils/*": ["src/utils/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true
  }
}